<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.libraryapp.ui.home.HomeFragment"
        android:label="Home">

        <action
            android:id="@+id/action_homeFragment_to_bookDetailFragment"
            app:destination="@id/bookDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookDetailFragment"
        android:name="com.example.libraryapp.ui.detail.BookDetailFragment"
        android:label="Detail">
        <action
        android:id="@+id/action_bookDetailFragment_to_chapterReaderFragment"
        app:destination="@id/chapterReaderFragment" />
    </fragment>

    <fragment
        android:id="@+id/chapterReaderFragment"
        android:name="com.example.libraryapp.ui.reader.ChapterReaderFragment"
        android:label="Reader" />

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.libraryapp.ui.auth.LoginFragment" />

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.libraryapp.ui.auth.RegisterFragment" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.libraryapp.ui.search.SearchFragment"
        android:label="Search" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.libraryapp.ui.profile.ProfileFragment"
        android:label="Search" />

</navigation>